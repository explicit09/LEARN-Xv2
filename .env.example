# ============================================================
# LEARN-X v2 — Environment Variables
# Copy to apps/web/.env.local and fill in values.
# Never commit .env.local or any file with real secrets.
# ============================================================

# ---- Supabase -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321          # local: supabase start output
NEXT_PUBLIC_SUPABASE_ANON_KEY=                           # local: supabase start output
SUPABASE_SERVICE_ROLE_KEY=                               # server-only — NEVER NEXT_PUBLIC_
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres  # local Supabase DB

# ---- AI Providers --------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ---- Trigger.dev -------------------------------------------
TRIGGER_SECRET_KEY=                                      # from trigger.dev dashboard

# ---- Upstash Redis -----------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Langfuse (LLM observability) --------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com                 # or self-hosted URL

# ---- App ---------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
