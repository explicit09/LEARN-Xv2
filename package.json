{
  "name": "learn-x",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test:unit": "turbo test:unit",
    "test:contract": "turbo test:contract",
    "test:integration": "turbo test:integration",
    "db:migrate": "pnpm --filter web db:migrate",
    "db:seed": "pnpm --filter web db:seed",
    "eval:retrieval": "pnpm --filter web eval:retrieval",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5",
    "prettier": "^3",
    "husky": "^9",
    "lint-staged": "^15"
  },
  "lint-staged": {
    "*.{ts,tsx,json,md,yaml}": "prettier --write"
  }
}
